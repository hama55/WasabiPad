{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PetaPad",
  "version": "0.2.0",
  "identifier": "app.petapad.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PetaPad",
        "width": 1100,
        "height": 750,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "../assets/petapad.ico"
    ]
  }
}
